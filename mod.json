	"settings": {
		"settings-title": {
			"type": "title",
			"name": "Settings have moved!",
			"description": "Due to the cluttered nature of the Geode settings menu, a custom settings menu has been created. It can be accessed from the mod icons in the garage or pause menus."
		},
		"mod-theme": {
			"type": "string",
			"name": "Mod Theme",
			"default": "Brown",
			"one-of": ["Brown", "Blue", "Green", "Purple", "Gray", "White"]
		}
	},
	"resources": {
		"sprites": [
			"resources/*.png"
		]
	}
