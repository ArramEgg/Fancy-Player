	"id": "arram.fancy-player",
	"name": "Fancy Player",
	"version": "v1.3.0",
	"developer": "Arram",
	"description": "Now you can be extra",
	"links": {
		"source": "https://github.com/ArramEgg/Fancy-Player"
	},
