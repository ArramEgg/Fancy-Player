{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "arram.fancy-player",
	"name": "Fancy Player",
	"version": "v1.2.1",
	"developer": "Arram",
	"description": "Now you can be extra",
	"links": {
		"source": "https://github.com/ArramEgg/Fancy-Player"
	},
	"tags": [
		"customization",
		"enhancement",
		"gameplay",
		"offline"
	],
	"settings": {
		"p1-title": {
			"type": "title",
			"name": "Player 1 Settings"
		},
		"p1-particles-title": {
			"type": "title",
			"name": "Configure Color of Player 1 Particles"
		},
		"p1-change-particles": {
			"name": "Override Built-in Particle Colors",
			"type": "bool",
			"default": true
		},
		"p1-rainbow-particles": {
			"name": "Rainbow Particles (Overrides startColor/finishColor)",
			"type": "bool",
			"enable-if": "p1-change-particles",
			"default": false
		},
		"p1-start-color": {
			"type": "rgba",
			"name": "Particles startColor",
			"enable-if": "p1-change-particles",
			"default": [61, 69, 255, 255]
		},
		"p1-finish-color": {
			"type": "rgba",
			"name": "Particles finishColor",
			"enable-if": "p1-change-particles",
			"default": [115, 122, 255, 255]
		},
		"p1-dash-fire-title": {
			"type": "title",
			"name": "Configure Color of Player 1 Dash Fire"
		},
		"p1-change-dash-fire": {
			"name": "Override Built-in Dash Fire Colors",
			"type": "bool",
			"default": true
		},
		"p1-rainbow-dash-fire": {
			"name": "Rainbow Dash Fire (Overrides Color)",
			"type": "bool",
			"enable-if": "p1-change-dash-fire",
			"default": false
		},
		"p1-dash-fire-color": {
			"name": "Dash Fire Color",
			"type": "rgb",
			"enable-if": "p1-change-dash-fire",
			"default": [0, 0, 255]
		},
		"p1-spider-dash-title": {
			"type": "title",
			"name": "Configure Color of Player 1 Spider Dash Effect"
		},
		"p1-change-spider-dash": {
			"name": "Override Built-in Spider Dash Colors",
			"type": "bool",
			"default": true
		},
		"p1-rainbow-spider-dash": {
			"name": "Rainbow Spider Dash (Overrides Color)",
			"type": "bool",
			"enable-if": "p1-change-spider-dash",
			"default": false
		},
		"p1-spider-dash-color": {
			"name": "Spider Dash Color",
			"type": "rgb",
			"enable-if": "p1-change-spider-dash",
			"default": [0, 0, 255]
		},
		"p2-title": {
			"type": "title",
			"name": "Player 2 Settings"
		},
		"p2-enable": {
			"name": "Enable Player 2 Customization",
			"type": "bool",
			"description": "When enabled, player 2 can be customized independently from player 1. Player 2 will use the same settings as player 1 when this setting is disabled.",
			"default": false
		},
		"p2-particles-title": {
			"type": "title",
			"name": "Configure Color of Player 2 Particles"
		},
		"p2-change-particles": {
			"name": "Override Built-in Particle Colors",
			"type": "bool",
			"enable-if": "p2-enable",
			"default": true
		},
		"p2-rainbow-particles": {
			"name": "Rainbow Particles (Overrides startColor/finishColor)",
			"type": "bool",
			"enable-if": "p2-change-particles && p2-enable",
			"default": false
		},
		"p2-start-color": {
			"type": "rgba",
			"name": "Particles startColor",
			"enable-if": "p2-change-particles && p2-enable",
			"default": [255, 255, 0, 255]
		},
		"p2-finish-color": {
			"type": "rgba",
			"name": "Particles finishColor",
			"enable-if": "p2-change-particles && p2-enable",
			"default": [255, 255, 40, 255]
		},
		"p2-dash-fire-title": {
			"type": "title",
			"name": "Configure Color of Player 2 Dash Fire"
		},
		"p2-change-dash-fire": {
			"name": "Override Built-in Dash Fire Colors",
			"type": "bool",
			"enable-if": "p2-enable",
			"default": true
		},
		"p2-rainbow-dash-fire": {
			"name": "Rainbow Dash Fire (Overrides Color)",
			"type": "bool",
			"enable-if": "p2-change-dash-fire && p2-enable",
			"default": false
		},
		"p2-dash-fire-color": {
			"name": "Dash Fire Color",
			"type": "rgb",
			"enable-if": "p2-change-dash-fire && p2-enable",
			"default": [255, 255, 0]
		},
		"p2-spider-dash-title": {
			"type": "title",
			"name": "Configure Color of Player 2 Spider Dash Effect"
		},
		"p2-change-spider-dash": {
			"name": "Override Built-in Spider Dash Colors",
			"type": "bool",
			"enable-if": "p2-enable",
			"default": true
		},
		"p2-rainbow-spider-dash": {
			"name": "Rainbow Spider Dash (Overrides Color)",
			"type": "bool",
			"enable-if": "p2-change-spider-dash && p2-enable",
			"default": false
		},
		"p2-spider-dash-color": {
			"name": "Spider Dash Color",
			"type": "rgb",
			"enable-if": "p2-change-spider-dash && p2-enable",
			"default": [255, 255, 0]
		},
		"global-title": {
			"type": "title",
			"name": "Global Settings"
		},
		"rgb-title": {
			"type": "title",
			"name": "RGB Options"
		},
		"rgb-speed": {
			"name": "RGB Fade Speed",
			"type": "float",
			"default": 0.2,
			"min": 0.1,
			"max": 1,
			"control": {
				"slider": true
			}
		},
		"misc-title": {
			"type": "title",
			"name": "Miscellaneous Options"
		},
		"change-radius": {
			"name": "Scale Radius Emitters (Type 1) Based on Player Size",
			"type": "bool",
			"default": false
		},
		"add-button": {
			"name": "Add Settings Button to Garage (Quicker Settings Access)",
			"type": "bool",
			"default": true
		}
	},
	"resources": {
		"sprites": [
			"resources/*.png"
		]
	}
}